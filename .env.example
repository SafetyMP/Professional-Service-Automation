# Copy to .env and adjust for your environment.
# Generate AUTH_SECRET: openssl rand -base64 32

# App connection (RLS role created by docker/init-db.sql)
DATABASE_URL="postgresql://psa_app:psa_app_dev@localhost:5440/psa?schema=public"

# Direct connection for Prisma migrations (postgres superuser)
DIRECT_URL="postgresql://postgres:postgres@localhost:5440/psa?schema=public"

# Required — session signing secret (never commit real values)
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# Public URL of the app (must match the port you run on)
AUTH_URL="http://localhost:3000"
