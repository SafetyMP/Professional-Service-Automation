{
  "name": "psa-platform",
  "version": "0.1.0",
  "description": "Professional Services Automation platform for consulting firms",
  "license": "Apache-2.0",
  "author": "SafetyMP",
  "homepage": "https://github.com/SafetyMP/Professional-Service-Automation#readme",
  "bugs": {
    "url": "https://github.com/SafetyMP/Professional-Service-Automation/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SafetyMP/Professional-Service-Automation.git"
  },
  "keywords": [
    "psa",
    "professional-services",
    "consulting",
    "time-tracking",
    "invoicing",
    "nextjs",
    "prisma"
  ],
  "private": false,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10.9.2 <11"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src lib tests scripts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed-demo.ts",
    "postinstall": "prisma generate",
    "check:boundaries": "tsx scripts/check-boundaries.ts",
    "screenshots": "node scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.9.1",
    "@hookform/resolvers": "^5.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.80.7",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.28",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "gifenc": "^1.0.3",
    "playwright": "^1.52.0",
    "pngjs": "^7.0.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
